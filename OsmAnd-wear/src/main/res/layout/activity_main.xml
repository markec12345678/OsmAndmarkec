<?xml version="1.0" encoding="utf-8"?>
<!--
    Main watch activity layout.
    Uses BoxInsetLayout to adapt content for round and square watches.
    Designed for quick glances while riding - large numbers, minimal text.
-->
<androidx.wear.widget.BoxInsetLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    android:padding="4dp">

    <!-- Stale data overlay - dims display when no phone connection -->
    <View
        android:id="@+id/stale_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#66000000"
        android:visibility="gone" />

    <!-- Connection lost indicator -->
    <View
        android:id="@+id/connection_status"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:layout_gravity="top|end"
        android:layout_margin="12dp"
        android:background="@android:color/holo_red_dark"
        app:boxedEdges="all" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        app:boxedEdges="all">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name_short"
            android:textColor="#80FFFFFF"
            android:textSize="10sp" />

        <!-- Lean Angle - PRIMARY display -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/lean_angle_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFeatureSettings="tnum"
                android:text="--"
                android:textColor="@android:color/white"
                android:textSize="52sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/lean_direction"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="4dp"
                android:text=""
                android:textColor="#BBFFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="-4dp"
            android:text="@string/label_lean_angle"
            android:textColor="#80FFFFFF"
            android:textSize="9sp" />

        <!-- G-Force -->
        <TextView
            android:id="@+id/gforce_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFeatureSettings="tnum"
            android:text="--"
            android:textColor="@android:color/white"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="-2dp"
            android:text="@string/label_gforce"
            android:textColor="#80FFFFFF"
            android:textSize="9sp" />

        <!-- Speed + Peaks row -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:orientation="horizontal">

            <!-- Speed -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingEnd="12dp">

                <TextView
                    android:id="@+id/speed_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFeatureSettings="tnum"
                    android:text="--"
                    android:textColor="@android:color/white"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_speed"
                    android:textColor="#80FFFFFF"
                    android:textSize="8sp" />
            </LinearLayout>

            <!-- Max Lean -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingEnd="12dp">

                <TextView
                    android:id="@+id/max_lean_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFeatureSettings="tnum"
                    android:text="--"
                    android:textColor="#BBFFFFFF"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_max_lean"
                    android:textColor="#80FFFFFF"
                    android:textSize="8sp" />
            </LinearLayout>

            <!-- Max G -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/max_g_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFeatureSettings="tnum"
                    android:text="--"
                    android:textColor="#BBFFFFFF"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_max_g"
                    android:textColor="#80FFFFFF"
                    android:textSize="8sp" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</androidx.wear.widget.BoxInsetLayout>
